# LINE Messaging API credentials
# Get from https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_USER_ID=your_user_id_here   # Target caregiver's LINE User ID (Uxxx...)

